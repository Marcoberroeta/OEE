<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Machine Stop List View -->
        <record id="pulsar_machine_stop_list_view" model="ir.ui.view">
            <field name="name">Machine Stop List</field>
            <field name="model">pulsar.machine_stop</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="machine_id"/>
                    <field name="start_time"/>
                    <field name="general_cause" widget="badge"/>
                    <field name="specific_cause"/>
                    <field name="duration_minutes"/>
                    <field name="status" widget="badge"/>
                    <field name="is_annotated" widget="boolean"/>
                </tree>
            </field>
        </record>

        <!-- Machine Stop Form View -->
        <record id="pulsar_machine_stop_form_view" model="ir.ui.view">
            <field name="name">Machine Stop Form</field>
            <field name="model">pulsar.machine_stop</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="machine_id"/>
                                <field name="production_order_id"/>
                                <field name="start_time"/>
                                <field name="end_time"/>
                            </group>
                            <group>
                                <field name="general_cause" widget="selection"/>
                                <field name="specific_cause"/>
                                <field name="duration_minutes" readonly="1"/>
                                <field name="status" readonly="1" widget="badge"/>
                            </group>
                        </group>
                        <group>
                            <field name="description" placeholder="Enter stop description..."/>
                            <field name="is_annotated" readonly="1"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_machine_stop_list" model="ir.actions.act_window">
            <field name="name">Machine Stops</field>
            <field name="res_model">pulsar.machine_stop</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="pulsar_machine_stop_list_view"/>
        </record>
    </data>
</odoo>
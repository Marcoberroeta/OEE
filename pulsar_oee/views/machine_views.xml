<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Machine List View -->
        <record id="pulsar_machine_list_view" model="ir.ui.view">
            <field name="name">Machine List</field>
            <field name="model">pulsar.machine</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="machine_type"/>
                    <field name="status"/>
                    <field name="availability" widget="percentage"/>
                    <field name="oee_percentage" widget="percentage"/>
                    <field name="current_operator_id"/>
                </tree>
            </field>
        </record>

        <!-- Machine Form View -->
        <record id="pulsar_machine_form_view" model="ir.ui.view">
            <field name="name">Machine Form</field>
            <field name="model">pulsar.machine</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Machine ID"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="machine_type"/>
                                <field name="status" widget="badge"/>
                                <field name="shift"/>
                                <field name="current_operator_id"/>
                            </group>
                            <group>
                                <field name="availability" widget="percentage"/>
                                <field name="oee_percentage" widget="percentage"/>
                                <field name="performance" widget="percentage"/>
                                <field name="current_speed"/>
                            </group>
                        </group>
                        <group>
                            <field name="current_sku_id"/>
                            <field name="current_operation"/>
                            <field name="operation_type" widget="badge"/>
                            <field name="total_products"/>
                        </group>
                        <group>
                            <field name="total_production_time"/>
                            <field name="total_stop_time"/>
                            <field name="quality"/>
                            <field name="elapsed_time"/>
                        </group>
                        <notebook>
                            <page string="Production Orders">
                                <field name="production_order_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="status"/>
                                        <field name="produced_quantity"/>
                                        <field name="start_datetime"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Machine Stops">
                                <field name="machine_stop_ids" readonly="1">
                                    <tree>
                                        <field name="start_time"/>
                                        <field name="general_cause"/>
                                        <field name="duration_minutes"/>
                                        <field name="status"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Machine Kanban View -->
        <record id="pulsar_machine_kanban_view" model="ir.ui.view">
            <field name="name">Machine Kanban</field>
            <field name="model">pulsar.machine</field>
            <field name="arch" type="xml">
                <kanban>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card">
                                <div class="oe_kanban_card_header">
                                    <strong><field name="name"/></strong>
                                    <span class="badge" t-attf-class="badge-#{record.status.raw_value == 'producing' and 'success' or 'warning'}">
                                        <field name="status"/>
                                    </span>
                                </div>
                                <div class="oe_kanban_card_body">
                                    <div>OEE: <field name="oee_percentage"/>%</div>
                                    <div>Availability: <field name="availability"/>%</div>
                                    <div>Operator: <field name="current_operator_id"/></div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_machine_list" model="ir.actions.act_window">
            <field name="name">Machines</field>
            <field name="res_model">pulsar.machine</field>
            <field name="view_mode">tree,form,kanban</field>
            <field name="view_id" ref="pulsar_machine_list_view"/>
        </record>
    </data>
</odoo>
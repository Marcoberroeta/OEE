<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- OEE Metrics List View -->
        <record id="pulsar_oee_metrics_list_view" model="ir.ui.view">
            <field name="name">OEE Metrics List</field>
            <field name="model">pulsar.oee_metrics</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="date"/>
                    <field name="machine_id"/>
                    <field name="total_availability" widget="percentage"/>
                    <field name="total_performance" widget="percentage"/>
                    <field name="total_quality" widget="percentage"/>
                    <field name="oee_value" widget="percentage"/>
                    <field name="total_produced"/>
                </tree>
            </field>
        </record>

        <!-- OEE Metrics Form View -->
        <record id="pulsar_oee_metrics_form_view" model="ir.ui.view">
            <field name="name">OEE Metrics Form</field>
            <field name="model">pulsar.oee_metrics</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="date"/>
                                <field name="machine_id"/>
                            </group>
                            <group>
                                <field name="oee_value" widget="percentage"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="total_availability" widget="percentage"/>
                                <field name="total_performance" widget="percentage"/>
                                <field name="total_quality" widget="percentage"/>
                            </group>
                            <group>
                                <field name="production_time"/>
                                <field name="planned_stop_time"/>
                                <field name="unplanned_stop_time"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="total_produced"/>
                                <field name="total_defective"/>
                                <field name="total_orders"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Dashboard Action -->
        <record id="action_oee_dashboard" model="ir.actions.client">
            <field name="name">OEE Dashboard</field>
            <field name="tag">dashboard</field>
            <field name="context">{}</field>
        </record>

        <!-- Metrics Action -->
        <record id="action_oee_metrics_list" model="ir.actions.act_window">
            <field name="name">OEE Metrics</field>
            <field name="res_model">pulsar.oee_metrics</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="pulsar_oee_metrics_list_view"/>
        </record>
    </data>
</odoo>